{
    "manifest_version": 2,
    "name": "Marklet",
    "version": "1.1",
    "description": "Run bookmarklets easily",
    "permissions": [
        "activeTab",
        "tabs"
    ],
    "browser_action": {
        "default_title": "Run Marklet"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "marklet@example.com",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}